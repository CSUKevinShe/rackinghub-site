# Cloudflare Pages Redirect Rules
# https://developers.cloudflare.com/pages/platform/redirects/

# Force trailing slash for directories (SEO consistency)
/planner /planner/ 301

# HTML extension fallback for extensionless URLs
/* /:splat.html 200

# Remove trailing slash for files (prevent double content)
# Note: Cloudflare Pages handles this automatically for .html files

# Planner coming-soon -> planner (backward compatibility)
/planner-coming-soon /planner/ 301
/planner-coming-soon/* /planner/ 301

# 404 custom page
/* /404.html 404
