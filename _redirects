# Cloudflare Pages Redirect Rules
# https://developers.cloudflare.com/pages/platform/redirects/

# Force trailing slash for directories (SEO consistency)
/planner /planner/ 301

# Extensionless URLs -> .html (Cloudflare Pages handles this natively)
# NOTE: Do NOT use /* /:splat.html 200 — it also matches images/css/js!
# Cloudflare Pages automatically maps /products/heavy-duty-racking
# to /products/heavy-duty-racking.html without needing a rule.

# Planner coming-soon -> planner (backward compatibility)
/planner-coming-soon /planner/ 301
/planner-coming-soon/* /planner/ 301

# 404 custom page
/* /404.html 404
